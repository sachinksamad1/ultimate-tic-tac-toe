{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && turbo run build --filter=server"
  },
  "deploy": {
    "startCommand": "node apps/server/dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100
  }
}
